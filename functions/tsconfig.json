{
  "compilerOptions": {
    "module": "Node16",
    "target": "es2022",
    "lib": [
      "es2022",
      "dom"
    ],
    "outDir": "lib",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node16"
  },
  "include": [
    "src/**/*.ts"
  ]
}
