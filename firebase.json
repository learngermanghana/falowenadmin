{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "falowenadmin",
      "disallowLegacyRuntimeConfig": true,
      "predeploy": [
        "node scripts/patchSheetRowManagementRoutes.mjs",
        "node scripts/patchOperationalSheetAutoSyncJobs.mjs",
        "node scripts/patchLiveClassUpdateScheduleSync.mjs"
      ],
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
